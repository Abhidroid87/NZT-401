<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0078d4;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#106ebe;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="64" cy="64" r="64" fill="url(#grad1)"/>
  
  <!-- Click symbol (mouse cursor with checkmark) -->
  <g transform="translate(30, 25)">
    <!-- Cursor -->
    <path d="M 0 0 L 12 8 L 8 12 L 0 4 Z" fill="white" opacity="0.9"/>
    <polygon points="1,1 11,9 7,11 1,3" fill="white"/>
  </g>
  
  <!-- Checkmark symbol -->
  <g transform="translate(55, 50)">
    <circle cx="20" cy="20" r="22" fill="none" stroke="white" stroke-width="2" opacity="0.8"/>
    <path d="M 12 20 L 18 26 L 28 16" stroke="white" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
  </g>
  
  <!-- Plus sign for rewards -->
  <g transform="translate(65, 25)">
    <path d="M 10 0 L 10 20 M 0 10 L 20 10" stroke="white" stroke-width="3" stroke-linecap="round"/>
  </g>
</svg>